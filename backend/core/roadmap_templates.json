      },
      {
        "week": 2,
        "title": "Gradient Descent & Optimization",
        "topics": ["Backpropagation Math", "Loss Functions", "Optimizers (Adam, SGD)"]
      },
      {
        "week": 3,
        "title": "Deep Neural Networks Tuning",
        "topics": ["Hyperparameter Optimization", "Regularization (Dropout, L2)", "Batch Normalization"]
      },
      {
        "week": 4,
        "title": "Convolutional Neural Networks (CNN)",
        "topics": ["Convolutions & Kernels", "Pooling Layers", "AlexNet/ResNet Architectures"]
      },
      {
        "week": 5,
        "title": "Recurrent Neural Networks (RNN)",
        "topics": ["Sequence Modeling", "LSTM & GRU cells", "Vanishing Gradients in RNNs"]
      },
      {
        "week": 6,
        "title": "Autoencoders & Generative Networks",
        "topics": ["Latent Spaces", "Variational Autoencoders (VAEs)", "Introduction to GANs"]
      }
    ]
  },
